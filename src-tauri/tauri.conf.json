{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "MazOS",
  "version": "1.0.0",
  "identifier": "com.manaz.mazos",
  "build": {
    "frontendDist": "../out",
    "devUrl": "http://localhost:3046",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build:desktop"
  },
  "app": {
    "windows": [
      {
        "title": "MazOS",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
